---
type SidebarItem = { label: string; href: string };
type Props = { sidebar?: SidebarItem[]; currentPath?: string };

const { sidebar = [], currentPath = "" } = Astro.props as Props;

const getActiveHref = (href: string, path: string) => {
  const hrefPath = href.replace(/\/$/, "") || "/";
  const cleanPath = path.replace(/\/$/, "") || "/";
  return hrefPath === cleanPath || (hrefPath !== "/" && cleanPath.startsWith(hrefPath));
};

const activeItem = sidebar.find((item) => getActiveHref(item.href, currentPath)) ?? sidebar[0];
---

<header class="site-header">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight text-slate-900 hover:text-sky-600 transition dark:text-slate-100">
      <span class="text-sky-500">🐀</span> rat
    </a>
    <div class="flex flex-row-reverse items-center gap-3 text-sm lg:flex-row">
      <button
        id="theme-toggle"
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-500 transition hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
        aria-label="Toggle dark mode"
      >
        <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
        <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
      </button>
      <a
        class="inline-flex items-center gap-2 rounded-full font-semibold text-slate-500 transition hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
        href="https://github.com/MaximeRivest/rat"
        target="_blank"
        rel="noreferrer"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span class="hidden lg:block">GitHub</span>
      </a>
      <!-- Mobile nav -->
      {sidebar.length > 0 && (
        <div class="lg:hidden">
          <div class="relative">
            <button
              id="docs-mobile-nav-trigger"
              class="inline-flex max-w-32 items-center gap-2 rounded-lg border border-slate-200 px-4 py-1 text-sm font-medium text-slate-700 transition hover:border-slate-300 dark:border-slate-700 dark:text-slate-300"
              aria-haspopup="menu"
              aria-expanded="false"
            >
              <span class="line-clamp-1 text-sm text-ellipsis">
                {activeItem?.label ?? "Navigate"}
              </span>
              <span class="text-lg text-slate-400">▾</span>
            </button>
            <div
              id="docs-mobile-nav-menu"
              class="absolute right-0 z-20 mt-2 hidden min-w-[200px] overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg"
              role="menu"
            >
              <div class="px-2 py-2">
                {sidebar.map((item) => (
                  <a
                    class:list={[
                      "block rounded-xl px-3 py-2 text-sm text-slate-700 hover:bg-slate-50",
                      { "bg-slate-100 font-medium text-slate-900": activeItem?.href === item.href },
                    ]}
                    href={item.href}
                    role="menuitem"
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
  <script is:inline>
    (() => {
      const navBar = document.querySelector(".site-header");
      const setScrolled = () => navBar.classList.toggle("is-scrolled", window.scrollY > 0);
      setScrolled();
      window.addEventListener("scroll", setScrolled, { passive: true });

      const trigger = document.getElementById("docs-mobile-nav-trigger");
      const menu = document.getElementById("docs-mobile-nav-menu");
      if (trigger && menu) {
        const toggle = (open) => {
          menu.classList.toggle("hidden", !open);
          trigger.setAttribute("aria-expanded", open ? "true" : "false");
        };
        trigger.addEventListener("click", (e) => { e.preventDefault(); toggle(menu.classList.contains("hidden")); });
        document.addEventListener("click", (e) => { if (!menu.contains(e.target) && !trigger.contains(e.target)) toggle(false); });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") toggle(false); });
      }
    })();
  </script>
</header>
