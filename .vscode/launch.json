{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Rat Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/vscode-rat"],
      "outFiles": ["${workspaceFolder}/vscode-rat/dist/**/*.js"],
      "preLaunchTask": "npm: watch - vscode-rat"
    }
  ]
}
