{
  "name": "rat",
  "displayName": "Rat — Run AnyThing",
  "description": "Run code in any file — Markdown cells, Python, R, Julia, JS, Shell — powered by rat kernels",
  "version": "0.1.0",
  "publisher": "maximerivest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maximerivest/rat.git",
    "directory": "vscode-rat"
  },
  "homepage": "https://github.com/maximerivest/rat/tree/main/vscode-rat#readme",
  "bugs": {
    "url": "https://github.com/maximerivest/rat/issues"
  },
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Notebooks",
    "Other"
  ],
  "keywords": [
    "rat",
    "run anything",
    "notebook",
    "markdown",
    "quarto",
    "python",
    "r",
    "julia",
    "repl",
    "mcp"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:python",
    "onLanguage:r",
    "onLanguage:julia",
    "onLanguage:javascript",
    "onLanguage:shellscript",
    "workspaceContains:**/*.qmd",
    "workspaceContains:**/*.rmd",
    "onCommand:rat.installCli"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rat",
          "title": "Rat Runtimes",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "rat": [
        {
          "id": "ratRuntimes",
          "name": "Runtimes"
        },
        {
          "id": "ratVariables",
          "name": "Variables",
          "type": "webview"
        },
        {
          "id": "ratInspector",
          "name": "Inspector",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "rat.runCell",
        "title": "Rat: Run Block",
        "icon": "$(play)"
      },
      {
        "command": "rat.runCellAndAdvance",
        "title": "Rat: Run Block and Advance"
      },
      {
        "command": "rat.runAbove",
        "title": "Rat: Run Above"
      },
      {
        "command": "rat.runAll",
        "title": "Rat: Run All Cells"
      },
      {
        "command": "rat.cancelExecution",
        "title": "Rat: Cancel Execution"
      },
      {
        "command": "rat.clearQueue",
        "title": "Rat: Clear Queue"
      },
      {
        "command": "rat.togglePause",
        "title": "Rat: Pause / Resume Queue"
      },
      {
        "command": "rat.clearOutputs",
        "title": "Rat: Clear All Outputs"
      },
      {
        "command": "rat.installCli",
        "title": "Rat: Install CLI"
      },
      {
        "command": "rat.showVariables",
        "title": "Rat: Show Variables"
      },
      {
        "command": "rat.stopKernel",
        "title": "Rat: Stop Kernel"
      },
      {
        "command": "rat.restartKernel",
        "title": "Rat: Restart Kernel"
      },
      {
        "command": "rat.selectRuntime",
        "title": "Rat: Select Runtime",
        "icon": "$(symbol-event)"
      },
      {
        "command": "rat.openRepl",
        "title": "Rat: Open REPL for Current File",
        "icon": "$(terminal)"
      },
      {
        "command": "rat.useNotebookScope",
        "title": "Rat: Use Notebook Scope"
      },
      {
        "command": "rat.useProjectScope",
        "title": "Rat: Use Project Scope"
      },
      {
        "command": "rat.useGlobalScope",
        "title": "Rat: Use Global Scope"
      },
      {
        "command": "rat.addRuntime",
        "title": "Rat: Add Runtime",
        "icon": "$(add)"
      },
      {
        "command": "rat.refreshRuntimes",
        "title": "Rat: Refresh Runtimes",
        "icon": "$(refresh)"
      },
      {
        "command": "rat.startRuntime",
        "title": "Start",
        "icon": "$(play)"
      },
      {
        "command": "rat.stopRuntime",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "rat.restartRuntime",
        "title": "Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "rat.removeRuntime",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "rat.insertCell",
        "title": "Rat: Insert Cell"
      }
    ],
    "viewsWelcome": [
      {
        "view": "ratRuntimes",
        "contents": "No runtimes for this workspace.\nRun a code cell or [add a runtime](command:rat.addRuntime) to get started."
      },
      {
        "view": "ratVariables",
        "contents": "Run a cell to see variables from the active rat runtime."
      },
      {
        "view": "ratInspector",
        "contents": "Put the cursor on a symbol in a rat file to inspect its full docstring here."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rat.addRuntime",
          "when": "view == ratRuntimes",
          "group": "navigation"
        },
        {
          "command": "rat.refreshRuntimes",
          "when": "view == ratRuntimes",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "rat.openRepl",
          "when": "rat.activeFile",
          "group": "navigation@10"
        },
        {
          "command": "rat.selectRuntime",
          "when": "rat.activeFile",
          "group": "navigation@11"
        }
      ],
      "view/item/context": [
        {
          "command": "rat.startRuntime",
          "when": "view == ratRuntimes && viewItem == savedRuntime",
          "group": "inline"
        },
        {
          "command": "rat.stopRuntime",
          "when": "view == ratRuntimes && viewItem == runningKernel",
          "group": "inline"
        },
        {
          "command": "rat.restartRuntime",
          "when": "view == ratRuntimes && viewItem == runningKernel",
          "group": "inline"
        },
        {
          "command": "rat.removeRuntime",
          "when": "view == ratRuntimes",
          "group": "2_modify"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rat.runCell",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && !editorReadonly && rat.activeFile && !notebookEditorFocused && !isCompositeNotebook && !findInputFocussed && !replaceInputFocussed && !inlineChatFocused"
      },
      {
        "command": "rat.runCellAndAdvance",
        "key": "shift+enter",
        "when": "editorTextFocus && rat.activeFile"
      },
      {
        "command": "rat.runAbove",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && rat.activeFile"
      },
      {
        "command": "rat.cancelExecution",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && rat.executing"
      },
      {
        "command": "rat.insertCell",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus && rat.activeFile"
      },
      {
        "command": "rat.openRepl",
        "key": "ctrl+alt+enter",
        "mac": "cmd+alt+enter",
        "when": "editorTextFocus && rat.activeFile"
      }
    ],
    "configuration": {
      "title": "Rat",
      "properties": {
        "rat.path": {
          "type": "string",
          "default": "rat",
          "description": "Path to the rat binary. Leave as \"rat\" to use the extension-managed CLI when installed, otherwise PATH."
        },
        "rat.autoInstall": {
          "type": "string",
          "enum": [
            "prompt",
            "never"
          ],
          "default": "prompt",
          "description": "When to offer installing the rat CLI into VS Code extension storage if it is not found."
        },
        "rat.runtimes": {
          "type": "object",
          "default": {},
          "description": "Map fence language to a named rat runtime, e.g. {\"python\": \"py-ml\"}"
        },
        "rat.maxOutputLines": {
          "type": "number",
          "default": 100,
          "description": "Maximum lines kept in an output cell (0 = unlimited)"
        },
        "rat.assetsDir": {
          "type": "string",
          "default": "_assets",
          "description": "Directory for plot images, relative to workspace root"
        }
      }
    },
    "languages": [
      {
        "id": "quarto",
        "aliases": [
          "Quarto"
        ],
        "extensions": [
          ".qmd"
        ]
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.json"
      },
      {
        "language": "quarto",
        "path": "./snippets/markdown.json"
      }
    ],
    "colors": [
      {
        "id": "rat.cellBackground",
        "description": "Background color for code cell body (use transparent values)",
        "defaults": {
          "dark": "#ffffff08",
          "light": "#00000008",
          "highContrast": "#ffffff0a"
        }
      },
      {
        "id": "rat.cellAccent",
        "description": "Left accent bar color for code cells",
        "defaults": {
          "dark": "#569cd650",
          "light": "#005cc540",
          "highContrast": "#569cd680"
        }
      },
      {
        "id": "rat.fenceColor",
        "description": "Text color for fence markers (triple backticks)",
        "defaults": {
          "dark": "#808080",
          "light": "#8b949e",
          "highContrast": "#aaaaaa"
        }
      },
      {
        "id": "rat.outputBackground",
        "description": "Background color for output blocks",
        "defaults": {
          "dark": "#ffffff06",
          "light": "#f6f8fa",
          "highContrast": "#ffffff0a"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npx @vscode/vsce package --no-dependencies",
    "lint": "npx tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.8"
  }
}
