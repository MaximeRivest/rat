{
  "name": "rat",
  "displayName": "Rat — Run AnyThing",
  "description": "Run code cells in Markdown and Quarto files, powered by rat kernels",
  "version": "0.1.0",
  "publisher": "maximerivest",
  "license": "MIT",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Notebooks",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:**/*.qmd",
    "workspaceContains:**/*.rmd"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rat",
          "title": "Rat Runtimes",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "rat": [
        {
          "id": "ratRuntimes",
          "name": "Runtimes"
        }
      ]
    },
    "commands": [
      { "command": "rat.runCell", "title": "Rat: Run Cell", "icon": "$(play)" },
      { "command": "rat.runCellAndAdvance", "title": "Rat: Run Cell and Advance" },
      { "command": "rat.runAbove", "title": "Rat: Run Above" },
      { "command": "rat.runAll", "title": "Rat: Run All Cells" },
      { "command": "rat.cancelExecution", "title": "Rat: Cancel Execution" },
      { "command": "rat.clearQueue", "title": "Rat: Clear Queue" },
      { "command": "rat.togglePause", "title": "Rat: Pause / Resume Queue" },
      { "command": "rat.clearOutputs", "title": "Rat: Clear All Outputs" },
      { "command": "rat.showVariables", "title": "Rat: Show Variables" },
      { "command": "rat.stopKernel", "title": "Rat: Stop Kernel" },
      { "command": "rat.restartKernel", "title": "Rat: Restart Kernel" },
      { "command": "rat.selectRuntime", "title": "Rat: Select Runtime", "icon": "$(symbol-event)" },
      { "command": "rat.addRuntime", "title": "Rat: Add Runtime", "icon": "$(add)" },
      { "command": "rat.refreshRuntimes", "title": "Rat: Refresh Runtimes", "icon": "$(refresh)" },
      { "command": "rat.startRuntime", "title": "Start", "icon": "$(play)" },
      { "command": "rat.stopRuntime", "title": "Stop", "icon": "$(debug-stop)" },
      { "command": "rat.restartRuntime", "title": "Restart", "icon": "$(debug-restart)" },
      { "command": "rat.removeRuntime", "title": "Remove", "icon": "$(trash)" },
      { "command": "rat.insertCell", "title": "Rat: Insert Cell" }
    ],
    "viewsWelcome": [
      {
        "view": "ratRuntimes",
        "contents": "No runtimes for this workspace.\nRun a code cell or [add a runtime](command:rat.addRuntime) to get started."
      }
    ],
    "menus": {
      "view/title": [
        { "command": "rat.addRuntime", "when": "view == ratRuntimes", "group": "navigation" },
        { "command": "rat.refreshRuntimes", "when": "view == ratRuntimes", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "rat.startRuntime", "when": "view == ratRuntimes && viewItem == savedRuntime", "group": "inline" },
        { "command": "rat.stopRuntime", "when": "view == ratRuntimes && viewItem == runningKernel", "group": "inline" },
        { "command": "rat.restartRuntime", "when": "view == ratRuntimes && viewItem == runningKernel", "group": "inline" },
        { "command": "rat.removeRuntime", "when": "view == ratRuntimes", "group": "2_modify" }
      ]
    },
    "keybindings": [
      {
        "command": "rat.runCell",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && rat.activeFile"
      },
      {
        "command": "rat.runCellAndAdvance",
        "key": "shift+enter",
        "when": "editorTextFocus && rat.activeFile"
      },
      {
        "command": "rat.runAbove",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && rat.activeFile"
      },
      {
        "command": "rat.cancelExecution",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && rat.executing"
      },
      {
        "command": "rat.insertCell",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus && rat.activeFile"
      }
    ],
    "configuration": {
      "title": "Rat",
      "properties": {
        "rat.path": {
          "type": "string",
          "default": "rat",
          "description": "Path to the rat binary"
        },
        "rat.runtimes": {
          "type": "object",
          "default": {},
          "description": "Map fence language to a named rat runtime, e.g. {\"python\": \"py-ml\"}"
        },
        "rat.maxOutputLines": {
          "type": "number",
          "default": 100,
          "description": "Maximum lines kept in an output cell (0 = unlimited)"
        },
        "rat.assetsDir": {
          "type": "string",
          "default": "_assets",
          "description": "Directory for plot images, relative to workspace root"
        }
      }
    },
    "languages": [
      {
        "id": "quarto",
        "aliases": ["Quarto"],
        "extensions": [".qmd"]
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.json"
      },
      {
        "language": "quarto",
        "path": "./snippets/markdown.json"
      }
    ],
    "colors": [
      {
        "id": "rat.cellBackground",
        "description": "Background color for code cell body (use transparent values)",
        "defaults": {
          "dark": "#ffffff08",
          "light": "#00000008",
          "highContrast": "#ffffff0a"
        }
      },
      {
        "id": "rat.cellAccent",
        "description": "Left accent bar color for code cells",
        "defaults": {
          "dark": "#569cd650",
          "light": "#005cc540",
          "highContrast": "#569cd680"
        }
      },
      {
        "id": "rat.fenceColor",
        "description": "Text color for fence markers (triple backticks)",
        "defaults": {
          "dark": "#808080",
          "light": "#8b949e",
          "highContrast": "#aaaaaa"
        }
      },
      {
        "id": "rat.outputBackground",
        "description": "Background color for output blocks",
        "defaults": {
          "dark": "#ffffff06",
          "light": "#f6f8fa",
          "highContrast": "#ffffff0a"
        }
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npx @vscode/vsce package --no-dependencies",
    "lint": "npx tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
